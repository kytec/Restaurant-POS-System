@page "/waiters"
@attribute [Authorize(Roles = AppRoles.AdminOnly)]

@inject StaffService StaffService
@inject StaffUserService StaffUserService
@inject ISnackbar Snackbar

<PageTitle>Staff Users</PageTitle>

<div class="page-header">
    <div>
        <MudText Typo="Typo.h4">Staff Users</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Create staff logins and assign POS roles</MudText>
    </div>
</div>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudText Typo="Typo.h6">Create Staff Login</MudText>
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Class="mt-3" Severity="Severity.Error">@_errorMessage</MudAlert>
    }
    <div class="dense-form mt-3">
        <MudTextField Label="Full name" @bind-Value="_newStaff.FullName" />
        <MudTextField Label="Email" InputType="InputType.Email" @bind-Value="_newStaff.Email" />
        <MudSelect T="StaffRole" Label="Role" @bind-Value="_newStaff.Role">
            @foreach (StaffRole role in Enum.GetValues<StaffRole>())
            {
                <MudSelectItem Value="@role">@role</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="CreateStaffAsync">Create User</MudButton>
    </div>
</MudPaper>

<MudTable Items="_staff" Dense="true" Hover="true">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Role</MudTh>
        <MudTh>Status</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.FullName</MudTd>
        <MudTd>@context.Role</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Success">Active</MudChip></MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<StaffMember> _staff = [];
    private StaffInput _newStaff = new();
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _staff = await StaffService.GetStaffAsync();
    }

    private async Task CreateStaffAsync()
    {
        _errorMessage = null;
        var result = await StaffUserService.CreateStaffUserAsync(_newStaff.FullName, _newStaff.Email, _newStaff.Role);

        if (!result.Succeeded)
        {
            _errorMessage = string.Join(" ", result.Errors.Select(error => error.Description));
            return;
        }

        _newStaff = new StaffInput();
        Snackbar.Add("Staff login created and invitation email queued.", Severity.Success);
        _staff = await StaffService.GetStaffAsync();
    }

    private sealed class StaffInput
    {
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public StaffRole Role { get; set; } = StaffRole.Waiter;
    }
}
